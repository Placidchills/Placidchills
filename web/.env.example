# App
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Database — PostgreSQL (Neon recommended for production)
# Local dev: use Neon free tier branch or local PostgreSQL instance
DATABASE_URL="postgresql://user:password@localhost:5432/placidchills?schema=public"

# Airtable — beat catalogue CMS
AIRTABLE_TOKEN=
AIRTABLE_BASE=
AIRTABLE_TABLE=Beats

# Razorpay — mastering & custom production payments
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# MailerLite — email list & free beat delivery
MAILERLITE_API_KEY=
MAILERLITE_GROUP_ID=

# Resend — transactional email (inquiry confirmations, payment emails)
RESEND_API_KEY=
EMAIL_FROM="Placidchills <hello@placidchills.com>"
ADMIN_EMAIL=

# Upstash Redis — rate limiting (optional in dev; uses in-memory fallback)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Payhip — beat store checkout (links per product in Airtable)
# No API key needed if using direct Payhip product URLs
